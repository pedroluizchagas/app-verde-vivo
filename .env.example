# =============================================================================
# Gestão Garden — variáveis de ambiente (Web / Next.js)
# Copie este arquivo para `.env.local` e preencha os valores reais.
# Nunca comite `.env.local`.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase — banco, auth e storage
# Origem: painel do projeto Supabase → Project Settings → API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave de service-role (admin). Apenas em rotas internas/webhooks. NUNCA expor no client.
SUPABASE_SERVICE_ROLE_KEY=
# JWT secret do projeto (Project Settings → API → JWT Settings). Usado para validar tokens mobile.
SUPABASE_JWT_SECRET=

# -----------------------------------------------------------------------------
# Stripe — pagamentos e assinaturas
# Origem: dashboard Stripe → Developers → API keys / Webhooks / Products
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
# Secret do endpoint de webhook (`/api/subscription/webhook`).
STRIPE_WEBHOOK_SECRET=
# IDs dos preços recorrentes dos planos.
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PLUS=

# -----------------------------------------------------------------------------
# Groq — IA (assistente Íris) e transcrição de áudio
# Origem: console Groq (https://console.groq.com)
# -----------------------------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TRANSCRIBE_MODEL=whisper-large-v3
GROQ_TRANSCRIBE_FORMAT=text
# Override opcional do modelo do assistente exposto ao client (mesmo valor de GROQ_MODEL por padrão).
NEXT_PUBLIC_ASSISTANT_MODEL=

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
# URL pública usada como base em redirects de auth e checkout. Em produção, use o domínio real.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Mobile (Expo) — definir em `mobile/.env` ou via EAS Secrets
# Variáveis prefixadas com EXPO_PUBLIC_ ficam disponíveis no bundle do app.
# =============================================================================

# Supabase (mobile usa as mesmas chaves públicas do projeto Supabase)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# URL para onde o Supabase redireciona após confirmação de email/recuperação de senha (deep link).
EXPO_PUBLIC_SUPABASE_REDIRECT_URL=
# Fallback usado em desenvolvimento quando EXPO_PUBLIC_SUPABASE_REDIRECT_URL não está setado.
NEXT_PUBLIC_DEV_SUPABASE_REDIRECT_URL=

# URLs do backend Next.js que o app mobile consome.
# CANONICAL_APP_URL: URL pública canônica (ex.: https://app.gestaogarden.com.br).
# APP_URL / API_URL: usados quando se aponta para um host alternativo (preview Vercel, túnel local etc.).
EXPO_PUBLIC_CANONICAL_APP_URL=
EXPO_PUBLIC_APP_URL=
EXPO_PUBLIC_API_URL=
# Override opcional do endpoint do assistente IA (default: APP_URL + /api/assistant).
EXPO_PUBLIC_ASSISTANT_API_BASE_URL=

# Integrações experimentais usadas em telas alternativas do mobile (Gemini/ChatGPT/Brave).
# Opcionais — só preencher se a tela correspondente for usada em desenvolvimento.
EXPO_PUBLIC_GEMINI_API_KEY=
EXPO_PUBLIC_OPENAI_API_KEY=
EXPO_PUBLIC_BRAVE_API_KEY=
